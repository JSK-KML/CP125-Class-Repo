import pandas as pd

def get_funded_science_depts(filename):
    df = pd.read_csv(filename)
    
    avg_budget = df['Budget.2024'].mean()
    
    filtered_df = df[ df['Faculty Name'] == 'Science']
    filtered_df = filtered_df[ filtered_df['Budget.2024'] > avg_budget ]
    
    result = filtered_df[['Dept.ID', 'Staff.Count']]
    
    return result